@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("UserRole");
    var token = Context.Session.GetString("AuthToken");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HacakthanChecker</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom Style -->
    <style>
            body {
                background-color: #f8f9fa;
            }

            .navbar-brand {
                font-weight: bold;
            }

            footer {
                margin-top: 50px;
                padding: 15px;
                text-align: center;
                background: #212529;
                color: white;
            }
    </style>
</head>

<body>

    <!-- ========================= -->
    <!-- NAVBAR -->
    <!-- ========================= -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                HacakthanChecker
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto">

                    @if (string.IsNullOrEmpty(token))
                    {
                        <!-- NOT LOGGED IN -->

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Register">Register</a>
                        </li>
                    }
                    else
                    {
                        <!-- LOGGED IN -->
                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="AdminDashboard">
                                    Admin Dashboard
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="UserDashboard">
                                    User Dashboard
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <!-- ========================= -->
    <!-- MAIN CONTENT -->
    <!-- ========================= -->

    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- ========================= -->
    <!-- FOOTER -->
    <!-- ========================= -->

    <footer>
        <p>© 2026 HacakthanChecker | All Rights Reserved</p>
    </footer>

    <!-- ========================= -->
    <!-- SCRIPTS -->
    <!-- ========================= -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>