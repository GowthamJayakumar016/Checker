@{
    ViewData["Title"] = "User Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <h2 class="mb-4">User Dashboard</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow p-3">
                <h5>Browse Hotels</h5>
                <p>Explore available hotels</p>
                <a href="#" class="btn btn-primary">View Hotels</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-3">
                <h5>Book Room</h5>
                <p>Make a new booking</p>
                <a asp-controller="Booking" asp-action="Book" class="btn btn-success">Book Now</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-3">
                <h5>My Bookings</h5>
                <p>View your reservations</p>
                <a asp-controller="Booking" asp-action="MyBookings" class="btn btn-info">View</a>
            </div>
        </div>

    </div>

    <div class="row mt-4">

        <div class="col-md-4">
            <div class="card shadow p-3">
                <h5>Logout</h5>
                <p>End session</p>
                <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger">Logout</a>
            </div>
        </div>

    </div>

</div>